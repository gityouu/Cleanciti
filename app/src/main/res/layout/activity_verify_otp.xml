<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:id="@+id/otpHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginTop="140dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/verify_your_number"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:id="@+id/otpDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/enter_the_6_digit_code_sent_to_233"
            android:textColor="#94a3b8"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingHorizontal="40dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/otpCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="22dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/card_surface"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/otpHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="6">

            <EditText
                android:id="@+id/otp1"
                style="@style/OtpBoxStyle"
                android:hint="@string/_0"
                android:textColor="#94a3b8"
                android:textColorHint="#94a3b8"
                tools:ignore="Autofill,LabelFor,TouchTargetSizeCheck" />

            <EditText
                android:id="@+id/otp2"
                style="@style/OtpBoxStyle"
                android:hint="@string/_0"
                android:textColorHint="#94a3b8"
                android:textColor="#94a3b8"
                tools:ignore="Autofill,LabelFor,TouchTargetSizeCheck" />

            <EditText
                android:id="@+id/otp3"
                style="@style/OtpBoxStyle"
                android:hint="@string/_0"
                android:textColorHint="#94a3b8"
                android:textColor="#94a3b8"
                tools:ignore="Autofill,LabelFor,TouchTargetSizeCheck" />

            <EditText
                android:id="@+id/otp4"
                style="@style/OtpBoxStyle"
                android:hint="@string/_0"
                android:textColorHint="#94a3b8"
                android:textColor="#94a3b8"
                tools:ignore="Autofill,LabelFor,TouchTargetSizeCheck" />

            <EditText
                android:id="@+id/otp5"
                style="@style/OtpBoxStyle"
                android:hint="@string/_0"
                android:textColor="#94a3b8"
                android:textColorHint="#94a3b8"
                tools:ignore="Autofill,LabelFor,TouchTargetSizeCheck" />

            <EditText
                android:id="@+id/otp6"
                style="@style/OtpBoxStyle"
                android:hint="@string/_0"
                android:textColorHint="#94a3b8"
                android:textColor="#94a3b8"
                tools:ignore="Autofill,LabelFor,TouchTargetSizeCheck" />

        </LinearLayout>

        <Button
            android:id="@+id/verifyButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/btn_primary"
            app:backgroundTint="@null"
            android:text="@string/verify_amp_continue"
            android:textAllCaps="false"
            android:textColor="#000"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/resendCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:text="@string/didn_t_receive_a_code_resend"
            android:textColor="#13ec49"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:ignore="TouchTargetSizeCheck" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>